diff --git a/scripts/cmake/vcpkg_download_distfile.cmake b/scripts/cmake/vcpkg_download_distfile.cmake
index 8a8efd205..0303e74ba 100644
--- a/scripts/cmake/vcpkg_download_distfile.cmake
