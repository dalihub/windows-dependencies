+                        execute_process(
+                            COMMAND ${DALI_SYSTEM_CURL}
+                                --fail
+                                --location
+                                --ssl-no-revoke
+                                --connect-timeout 10
+                                --speed-limit 1024
+                                --speed-time 10
+                                --retry 5
+                                --retry-delay 1
+                                --output "${download_file_path_part}"
+                                ${curl_header_arguments}
+                                "${url}"
+                            RESULT_VARIABLE dali_curl_status
+                        )
+                        if("${dali_curl_status}" STREQUAL "0")
+                            set(download_success 1)
+                            break()
+                        endif()
+                    endif()
+                endif()
                 file(DOWNLOAD ${url} "${download_file_path_part}" STATUS download_status ${request_headers})
                 list(GET download_status 0 status_code)
                 if (NOT "${status_code}" STREQUAL "0")
