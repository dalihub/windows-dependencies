@@ -159,6 +159,37 @@ function(vcpkg_download_distfile VAR)
                         list(APPEND request_headers HTTPHEADER ${header})
                     endforeach()
                 endif()
+                if(WIN32)
+                    find_program(DALI_SYSTEM_CURL NAMES curl.exe curl)
+                    if(DALI_SYSTEM_CURL)
+                        set(curl_header_arguments)
+                        if(vcpkg_download_distfile_HEADERS)
+                            foreach(header ${vcpkg_download_distfile_HEADERS})
+                                list(APPEND curl_header_arguments --header "${header}")
+                            endforeach()
+                        endif()
